<mxfile host="app.diagrams.net">
  <diagram name="As-Is deposit process" id="asis1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" page="1" pageWidth="1400" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="pool" value="As-Is: Irish rental deposit process (manual)" style="swimlane;horizontal=0;whiteSpace=wrap;startSize=30;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1320" height="720" as="geometry"/>
        </mxCell>
        <mxCell id="laneT" value="Tenant" style="swimlane;horizontal=0;startSize=30;" vertex="1" parent="pool">
          <mxGeometry x="30" y="0" width="1290" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="laneL" value="Landlord" style="swimlane;horizontal=0;startSize=30;" vertex="1" parent="pool">
          <mxGeometry x="30" y="220" width="1290" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="laneR" value="RTB" style="swimlane;horizontal=0;startSize=30;" vertex="1" parent="pool">
          <mxGeometry x="30" y="480" width="1290" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="start" value="Tenancy agreed" style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;" vertex="1" parent="laneT">
          <mxGeometry x="60" y="80" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="t1" value="Pay deposit to landlord (bank transfer)" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneT">
          <mxGeometry x="160" y="75" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t2" value="Vacate and request deposit back" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneT">
          <mxGeometry x="640" y="75" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="t3" value="Lodge dispute with RTB" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneT">
          <mxGeometry x="1050" y="75" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="l1" value="Hold deposit in personal account" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneL">
          <mxGeometry x="160" y="60" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="Informal move-in photos (unverified)" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneL">
          <mxGeometry x="380" y="60" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="Assess damage at move-out (subjective)" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneL">
          <mxGeometry x="640" y="60" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="gw" value="Agree on split?" style="rhombus;whiteSpace=wrap;fillColor=#fff2cc;" vertex="1" parent="laneL">
          <mxGeometry x="870" y="55" width="110" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="Refund agreed amount (days to weeks)" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneL">
          <mxGeometry x="870" y="170" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="endok" value="Deposit returned" style="ellipse;whiteSpace=wrap;fillColor=#d5e8d4;strokeWidth=3;" vertex="1" parent="laneL">
          <mxGeometry x="1090" y="175" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="r1" value="Case registered and evidence gathered" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneR">
          <mxGeometry x="1050" y="40" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="Adjudication hearing (6 to 12 months)" style="rounded=1;whiteSpace=wrap;" vertex="1" parent="laneR">
          <mxGeometry x="1050" y="130" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="endrtb" value="Ruling issued" style="ellipse;whiteSpace=wrap;fillColor=#f8cecc;strokeWidth=3;" vertex="1" parent="laneR">
          <mxGeometry x="960" y="140" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="start" target="t1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="t1" target="l1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="l1" target="l2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="l2" target="t2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="t2" target="l3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="l3" target="gw"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" value="yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="gw" target="l4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="l4" target="endok"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" value="no" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="gw" target="t3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="t3" target="r1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="r1" target="r2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" parent="pool" source="r2" target="endrtb"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
